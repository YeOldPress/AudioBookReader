{
  "name": "heavens-river-reader",
  "version": "1.0.0",
  "description": "Heaven's River — Audiobook Reader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.heavensriver.reader",
    "productName": "Heaven's River",
    "mac": {
      "category": "public.app-category.entertainment",
      "target": "dmg"
    },
    "files": [
      "main.js",
      "reader.html",
      "sync/**",
      "audio/**"
    ]
  }
}
